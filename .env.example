# ─────────────────────────────────────────────────
# YT Studio — Environment Variables
# Bu dosyayı kopyala: cp .env.example .env
# Sonra kendi değerlerinle doldur
# ─────────────────────────────────────────────────

# Kanal klasörü (Docker kullanıyorsan değiştirme)
YT_BASE_DIR=/data/channels

# Video arşiv klasörü
YT_ARCHIVE_DIR=/data/archive

# Google OAuth client_secrets.json dosyanın yolu
YT_CLIENT_SECRETS=./secrets/client_secrets.json

# Google Calendar OAuth callback URL
# Docker dışı için: http://localhost:5055/gcal/callback
GCAL_REDIRECT_URI=http://localhost:5055/gcal/callback

# Gemini API — başlık/açıklama üretimi için
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask gizli anahtar (rastgele uzun bir string)
FLASK_SECRET_KEY=change_this_to_a_random_string_min_32_chars
